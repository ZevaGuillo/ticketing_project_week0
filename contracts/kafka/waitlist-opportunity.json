{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Waitlist Opportunity Granted Event",
  "description": "Event published when a user receives a purchase opportunity for a waitlisted seat",
  "type": "object",
  "properties": {
    "opportunityId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the opportunity"
    },
    "waitlistEntryId": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the waitlist entry"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "User who received the opportunity"
    },
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Event identifier"
    },
    "seatId": {
      "type": "string",
      "format": "uuid",
      "description": "Seat identifier"
    },
    "section": {
      "type": "string",
      "description": "Seat section name"
    },
    "opportunityTTL": {
      "type": "integer",
      "description": "Time-to-live in seconds (default: 600 = 10 min)",
      "minimum": 60,
      "maximum": 3600
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the opportunity was created"
    },
    "idempotencyKey": {
      "type": "string",
      "description": "Unique key for deduplication"
    },
    "status": {
      "type": "string",
      "enum": ["OFFERED", "EXPIRED", "USED"],
      "description": "Opportunity status"
    }
  },
  "required": [
    "opportunityId",
    "waitlistEntryId",
    "userId",
    "eventId",
    "seatId",
    "section",
    "createdAt",
    "status"
  ],
  "additionalProperties": false
}